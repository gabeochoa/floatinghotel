# Item 20: Commit hashes removed from graph rows
# Hash is only visible in commit detail view, not inline
make_test_repo
resize 1280 720
wait_for_refresh
wait_frames 30

# Commit subjects should still be visible
expect_text "Add contributing guidelines"
expect_text "Add unit tests for utils"

# Short hashes should NOT appear as visible text in graph rows
expect_no_text "7499ed5"
expect_no_text "7d34b0a"

